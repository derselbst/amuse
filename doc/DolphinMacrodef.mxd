Macrostep=$38,$00,$00,$00,$E8,$03,$00,$00
Macrostep=$0F,$00,$00,$00,$00,$01,$E8,$03
Macrostep=$07,$00,$00,$01,$00,$00,$E8,$03
Macrostep=$11,$00,$00,$00,$00,$00,$00,$00
Macrostep=$00,$00,$00,$00,$00,$00,$00,$00
[Template_end]

