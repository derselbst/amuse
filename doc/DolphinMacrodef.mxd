[$28]
Type = Structure
Name = TRAP_EVENT
Icon =branch.ico

Mainhint=Sets a trap to a desired macro and step if an event is triggered. The macro can go on proceeding and at the time the keyoff is received it jumps directly to the new macro and step.

Shorthint=Sets a trap on event

Value = 8bit@byte1, MinValue=0, MaxValue=2, PresetValue=0, Type=VAL_NORMAL, Reference=none, Hint=Event
Value = 16bit@byte2, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_SoundMacroID, Reference=SoundMacro , Hint=SoundMacro ID
Value = 16bit@byte4, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=SoundMacroStep , Hint=SoundMacro step

;-------------------------------------------------------------------------------------
