;
; **************************************************************************************
;

;-------------------------------------------------------------------------------------
[$00]
Type = Structure
Name = END
Icon =stop.ico

MainHint=This always is the last macro comand. It cannot be deleted from the macro. It terminates the macro permanently.

ShortHint=End of the macro

;------------------------------------------------------------------------------------
[$01]
Type = Structure
Name = STOP
Icon =stop.ico

MainHint=Has the same functionality as END, but can be freely placed within the macro.

ShortHint=Similar to END

;-------------------------------------------------------------------------------------
[$02]
Type = Structure
Name = SPLITKEY
Icon =branch.ico

MainHint=This command is used to conditionally change the flow of execution in the current macro. The macro program will jump to the given macrostep inside the specified macro if the current key is higher than or equal to the key parameter.

ShortHint=Splits the macro flow depending on the midikey

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=60, Type=VAL_Key, Reference=None , Hint=Keynumber
Value = 16bit@byte2, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_SoundMacroID, Reference=SoundMacro, Hint=SoundMacro ID
Value = 16bit@byte4, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=SoundMacroStep, Hint=SoundMacro step

;-------------------------------------------------------------------------------------
[$03]
Type = Structure
Name = SPLITVEL
Icon =branch.ico

MainHint=This command is used to conditionally change the flow of execution in the current macro. The macro program will jump to the given macrostep inside the specified macro if the current velocity is higher than or equal to the velocity parameter.

ShortHint=Splits the macro flow depending on the velocity

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=100, Type=VAL_Normal, Reference=None , Hint= Velocity
Value = 16bit@byte2, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_SoundMacroID, Reference=SoundMacro, Hint=SoundMacro ID
Value = 16bit@byte4, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=SoundMacroStep, Hint=SoundMacro step

;-------------------------------------------------------------------------------------
[$06]
Type = Structure
Name = GOTO
Icon =branch.ico

MainHint=Performs an unconditional jump to the specified location.

ShortHint=Jump to another macro

Value = 16bit@byte2, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_SoundMacroID, Reference=SoundMacro , Hint=SoundMacro ID
Value = 16bit@byte4, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=SoundMacroStep , Hint=SoundMacro step

;-------------------------------------------------------------------------------------
[$0a]
Type = Structure
Name = SPLITMOD
Icon =branch.ico

MainHint=This command is used to conditionally change the flow of execution in the current macro. The macro program will jump to the given macrostep inside the specified macro if the current modulation value is higher or same the modulation parameter.

ShortHint=Splits the macro flow depending on modwheel

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=64, Type=VAL_Normal, Reference=None , Hint=Mod value
Value = 16bit@byte2, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_SoundMacroID, Reference=SoundMacro, Hint=SoundMacro ID
Value = 16bit@byte4, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=SoundMacroStep, Hint=SoundMacro step

;-------------------------------------------------------------------------------------
[$0b]
Type = Control
Name = PIANOPAN
Icon =pan.ico

MainHint=This macro command is especially designed to give instruments like a piano a naturalistic stereo behaviour. The current key will be used to calculate a panning position. First the key is converted to an offset by subtracting the centerkey. Next the scale is applied. A scale of 127 will give you the full range, while a scale of 0 will eleminate any offset. Finally the centerpan is added. This last value can be viewed as the position of the instrument in the room. Since the final values may exceed the normal panning range, illegal values are clipped.

ShortHint=Piano stereo panning

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=127, Type=VAL_Normal, Reference=None , Hint=Scale
Value = 8bit@byte2, MinValue=0, MaxValue=127, PresetValue=36, Type=VAL_Normal, Reference=None , Hint=Centerkey
Value = 8bit@byte3, MinValue=0, MaxValue=127, PresetValue=64, Type=VAL_Panning, Reference=None , Hint=Centerpan

;-------------------------------------------------------------------------------------
[$0c]
Type = Volume
Name = SETADSR
Icon =adsr.ico

MainHint=The data from the specified table will be used to define an ADSR to be used with the voice.

ShortHint=Define ADSR Envelope

Value = 16bit@byte1, MinValue=0, MaxValue=16383, PresetValue=0, Type=VAL_TableID, Reference=Table, Hint=Table-ID (ADSR)
Value = 8bit@byte3, MinValue=0, MaxValue=1, PresetValue=0, Type=VAL_Switch, Reference=None, Hint=DLS mode

;-------------------------------------------------------------------------------------
[$16]
Type = Volume
Name = SETADSRCTRL
Icon =adsr.ico

MainHint=The four controllers' values specify the ADSR parameters of the ADSR to be set

ShortHint=Define ADSR Envelope via MIDI controllers

Value = 8bit@byte1, MinValue=0, MaxValue=255, PresetValue=20, Type=VAL_Normal, Reference=None, Hint=Attack
Value = 8bit@byte2, MinValue=0, MaxValue=255, PresetValue=22, Type=VAL_Normal, Reference=None, Hint=Decay
Value = 8bit@byte3, MinValue=0, MaxValue=255, PresetValue=23, Type=VAL_Normal, Reference=None, Hint=Sustain
Value = 8bit@byte4, MinValue=0, MaxValue=255, PresetValue=24, Type=VAL_Normal, Reference=None, Hint=Release

;-------------------------------------------------------------------------------------
[$0e]
Type = Control
Name = PANNING
Icon =pan.ico

MainHint=Sets the panning to be used with the macro. If no panning is specified the default center panning will be used. The panning parameter specifies the position (0=Left, 64=Center, 127=Right). The time and width parameters enable to cause an automated pan-sweep. The panning will move from the current location to the new one specified by the signed offset width in time ms. If these parameters are zero, the new panning will be set immediately.

ShortHint=Panning

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=64, Type=VAL_Panning, Reference=None , Hint=Pan position
Value = 16bit@byte2, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=None , Hint=Time ms
Value = 8bit@byte4, MinValue=-128, MaxValue=127, PresetValue=0, Type=VAL_Signed, Reference=None ,Hint=Width

;-------------------------------------------------------------------------------------
[$0f]
Type = Volume
Name = ENVELOPE
Icon =adsr.ico

MainHint=Start a software envelope. The velocity of the current macro will be faded to the new one in the time specified by the ticks parameter. If the millisec flag is set ms will be used instead of ticks. The new volume is calculated just as described in SCALEVOLUME. The volume sweep may be of lower quality than the hardware ADSR.

ShortHint=Software envelope

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=0, Type=VAL_Volume, Reference=None , Hint=Scale
Value = 8bit@byte2, MinValue=0, MaxValue=127, PresetValue=0, Type=VAL_Volume, Reference=None , Hint=Add
Value = 16bit@byte3, MinValue=0, MaxValue=16383, PresetValue=0, Type=VAL_TableID, Reference=Table, Hint=Table-ID (Curve)
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=ms switch
Value = 16bit@byte6, MinValue=0, MaxValue=65535, PresetValue=500, Type=VAL_Normal, Reference=None, Hint=Ticks/Millisec.

;-------------------------------------------------------------------------------------
[$10]
Type = Sample
Name = STARTSAMPLE
Icon =sample.ico

Mainhint=Starts a sample on the current voice. An offset in sample-units can be applied. The mode-parameter can be used to select a scaling of the offset through the velocity (1=negative, 2=positive).

Shorthint=Play a sample

Value = 16bit@byte1, Minvalue=0, Maxvalue=$ffff, Type=VAL_SAMPLEID, Reference=Sample, Hint=Sample-ID
Value = 8bit@byte3, MinValue=0, MaxValue=2, Type=VAL_Normal, Reference=None, Hint=Mode--->
Value = 32bit@byte4, Minvalue=0, Maxvalue=$ffffff, Type=VAL_UNSIGNED, Reference=None, Hint=Offset

;-------------------------------------------------------------------------------------
[$11]
Type = Sample
Name = STOPSAMPLE
Icon =sample.ico

Mainhint=Stops the sample playback immediately by sending a keyoff and setting the ADSR to a very short release time. Click-sounds will be avoided as far as possible.

Shorthint=Stop sample

;-------------------------------------------------------------------------------------
[$13]
Type = Structure
Name = SPLITRND
Icon =branch.ico

MainHint=This command is used to conditionally change the flow of execution in the current macro. The lower the RND value (0-255) the higher the possibility that the program will jump to the given macrostep inside the specified macro.

ShortHint=Splits the macro flow depending on random

Value = 8bit@byte1, MinValue=0, MaxValue=255, PresetValue=128, Type=VAL_Normal, Reference=None , Hint=RND
Value = 16bit@byte2, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_SoundMacroID, Reference=SoundMacro, Hint=SoundMacro ID
Value = 16bit@byte4, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=SoundMacroStep, Hint=SoundMacro step

;-------------------------------------------------------------------------------------
[$14]
Type = Volume
Name = FADE-IN
Icon =adsr.ico

MainHint=Start a software envelope. The volume will be faded from 0 to the calculated value (velocity scale+add) in the time specified by the ticks parameter. If the millisec flag is set ms will be used instead of ticks. The new volume is calculated just as described in SCALEVOLUME. The volume sweep may be of lower quality than the hardware ADSR. This command can also be used to prevent a click noise at the start of a sample even if the fade time is very fast (18 ms).

ShortHint=Fade volume in

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=127, Type=VAL_Volume, Reference=None , Hint=Scale
Value = 8bit@byte2, MinValue=0, MaxValue=127, PresetValue=0, Type=VAL_Volume, Reference=None , Hint=Add
Value = 16bit@byte3, MinValue=0, MaxValue=16383, PresetValue=0, Type=VAL_TableID, Reference=Table, Hint=Table-ID (Curve)
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=ms switch
Value = 16bit@byte6, MinValue=0, MaxValue=65535, PresetValue=18, Type=VAL_Normal, Reference=None, Hint=Ticks/Millisec.

;-------------------------------------------------------------------------------------
[$0d]
Type = Volume
Name = SCALEVOLUME
Icon =volume.ico

MainHint=Calculates a new volume for the current voice by scaling the velocity. The velocity is either passed to the macro by the sequencer or the effect handler. A scale of 127 equals 100%, smaller values scale down, larger up. In addition to the simple scale an offset can be specified in the 'add' parameter. The result of this calculation can be passed through a curve which will act as a translation table. A value of 0 in the curve parameter will disable this feature.

ShortHint=Calculate new volume using velocity

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=127, Type=VAL_Volume, Reference=None , Hint=Scale
Value = 8bit@byte2, MinValue=0, MaxValue=127, PresetValue=0, Type=VAL_Volume, Reference=None , Hint=Add
Value = 16bit@byte3, MinValue=0, MaxValue=16383, PresetValue=0, Type=VAL_TableID, Reference=Table, Hint=Table-ID (Curve)
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=Org vol

;-------------------------------------------------------------------------------------
[$15]
Type = Control
Name = SPANNING
Icon =pan.ico

MainHint=Sets the surround panning to be used with the macro. If no panning is specified the default front panning will be used. The panning parameter specifies the position (0=Left, 64=Center, 127=Right). The time and width parameters enable to cause an automated pan-sweep. The panning will move from the current location to the new one specified by the signed offset width in time ms. If these parameters are zero, the new panning will be set immediately.

ShortHint=Surround Panning

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=64, Type=VAL_Panning, Reference=None , Hint=Pan position
Value = 16bit@byte2, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=None , Hint=Time ms
Value = 8bit@byte4, MinValue=-128, MaxValue=127, PresetValue=0, Type=VAL_Signed, Reference=None ,Hint=Width

;-------------------------------------------------------------------------------------
[$12]
Type = Control
Name = KEYOFF
Icon =switch.ico

Mainhint=Sends a keyoff to the currently used voice, but does not change the ADSR. This command should be used instead of STOPSAMPLE to finish sample playback if any ADSR has been set.

Shorthint=Send keyoff to voice

;-------------------------------------------------------------------------------------
[$17]
Type = Pitch
Name = RNDNOTE
Icon =note.ico

Mainhint=Sets random pitch. Note lo is the lower end of the range, note hi the upper one. The detune value will added after the random pitch is calculated. It is specified in cents. If the fixed/free flag is set the pitch will be generated freely inside the range without respect to any key steps.

Shorthint=Random pitch

Value = 8bit@byte1, MinValue=-127, MaxValue=127, PresetValue=48, Type=VAL_Signed, Reference=None , Hint=Note Lo
Value = 8bit@byte2, MinValue=0, MaxValue=99, PresetValue=0, Type=VAL_Percent, Reference=None , Hint=Detune
Value = 8bit@byte3, MinValue=-127, MaxValue=127, PresetValue=72, Type=VAL_Signed, Reference=None , Hint=Note Hi
Value = 8bit@byte4, MinValue=0, MaxValue=1, PresetValue=0, Type=VAL_Switch, Reference=None , Hint=Fixed/Free
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=0, Type=VAL_Switch, Reference=None , Hint=Abs/Rel

;-------------------------------------------------------------------------------------
[$18]
Type = Pitch
Name = ADDNOTE
Icon =note.ico

Mainhint=Recalculates the current pitch/key by adding add keysteps to the current key and applying the detune value in cents. Add is a signed value. The last two parameters are zero by default. If they are non-zero they will be used like in WAIT to suspend the execution of the current macro for a given time interval.

Shorthint=Add note

Value = 8bit@byte1, MinValue=-128, MaxValue=127, PresetValue=0, Type=VAL_Signed, Reference=None , Hint=Add
Value = 8bit@byte2, MinValue=-99, MaxValue=99, PresetValue=0, Type=VAL_Signed, Reference=None , Hint=Detune
Value = 8bit@byte3, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=org key
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=ms switch
Value = 16bit@byte6, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=None,Hint=Ticks/Millisec.

;-------------------------------------------------------------------------------------
[$19]
Type = Pitch
Name = SETNOTE
Icon =note.ico

Mainhint=Sets the current pitch/key to the new value specified by key. After this the detune specified in cents will be applied. The last two parameters are zero by default. If they are non-zero they will be used like in WAIT to suspend the execution of the current macro for a given time interval.

Shorthint=Set note by a fixed key

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=60, Type=VAL_Key, Reference=None , Hint=Key
Value = 8bit@byte2, MinValue=-99, MaxValue=99, PresetValue=0, Type=VAL_Signed, Reference=None , Hint=Detune
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=ms switch
Value = 16bit@byte6, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=None,Hint=Ticks/Millisec.

;-------------------------------------------------------------------------------------
[$1a]
Type = Pitch
Name = LASTNOTE
Icon =note.ico

Mainhint=Recalculates the current pitch/key by adding 'add' keysteps to the last key played on this MIDI (!) channel and applying the detune value in cents. The 'add' parameter is a signed value. The last two parameters are zero by default. If they are non-zero they will be used like in WAIT to suspend the execution of the current macro for a given time interval.

Shorthint=Set last note of the current channel

Value = 8bit@byte1, MinValue=-128, MaxValue=127, PresetValue=0, Type=VAL_Signed, Reference=None , Hint=Add
Value = 8bit@byte2, MinValue=-99, MaxValue=99, PresetValue=0, Type=VAL_Signed, Reference=None , Hint=Detune
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=ms switch
Value = 16bit@byte6, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=None,Hint=Ticks/Millisec.

;-------------------------------------------------------------------------------------
[$1b]
Type = Setup
Name = PORTAMENTO
Icon =note.ico

Mainhint=Setup the mode for the portamento operation. If state equals zero the portamento will be disabled, while 1 enables it. A value of 2 keeps the state unchanged. By default the portamento is controlled by the MIDI portamento controller. The time parameter controls the time needed to reach the current key. By default this is 500ms. Type defines the type of portamento function desired. Zero performes the portamento only if the last key is still depressed, while 1 performes it all the time. A legato function can be achived by setting the time parameter to zero.

Shorthint=Set portamento mode and time

Value = 8bit@byte1, MinValue=0, MaxValue=2, PresetValue=1, Type=VAL_Normal, Reference=None , Hint=Port. State
Value = 8bit@byte2, MinValue=0, MaxValue=1, PresetValue=0, Type=VAL_Normal, Reference=None , Hint=Port. Type
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=ms switch
Value = 16bit@byte6, MinValue=0, MaxValue=65535, PresetValue=0, Type=VAL_Normal, Reference=None,Hint=Ticks/Millisec.

;-------------------------------------------------------------------------------------
[$1f]
Type = Pitch
Name = SETPITCH
Icon =note.ico

Mainhint=Directly sets the frequency to be used to playback a sample. The fine parameter is not supported by all platforms since most platforms do not have such a fine resolution in selecting the playback frequency (Actually 10Hz steps are quite normal).

Shorthint=Sets the pitch directly

Value = 24bit@byte1, MinValue=0, MaxValue=$ffffff, PresetValue=22050, Type=Val_Unsigned, Reference=None, Hint=Frequency (Hz)
Value = 16bit@byte4, MinValue=0, MaxValue=65535, PresetValue=0, Type=Val_Unsigned, Reference=None, Hint=Fine

;-------------------------------------------------------------------------------------
[$1c]
Type = Pitch
Name = VIBRATO
Icon =wave.ico

Mainhint=Add a vibrato to the voice currently used to play the macro. Vibrato means that the pitch is modulated by a triangular waveform with a period specified by ticks. If the millisec flag is set the period is given in ms instead of ticks. The amplitude of the waveform is given by the number of keysteps it should go up or down. Level Note is a signed value! If it is negative the pitch offset will go down first, if it is positive the offset will go up first. LevelFine is specified in cents. If the modulation flag is set to 1 the values from the modulation wheel will be used to scale the vibrato; if it is set to 2 the aftertouch information will be used instead. 0 disables any scaling by controllers.

Shorthint=Add a vibrato

Value = 8bit@byte1, MinValue=-127, MaxValue=127, PresetValue=0, Type=VAL_Signed, Reference=None , Hint=Level note
Value = 8bit@byte2, MinValue=-99, MaxValue=99, PresetValue=15, Type=VAL_Signed, Reference=None , Hint=Level fine
Value = 8bit@byte3, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=Modwheel flag
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=ms switch
Value = 16bit@byte6, MinValue=0, MaxValue=65535, PresetValue=250, Type=VAL_Normal, Reference=None, Hint=Ticks/Millisec.

;-------------------------------------------------------------------------------------
[$1d]
Type = Pitch
Name = PITCHSWEEP1
Icon =wave.ico

Mainhint=Adds add times times to the current pitch. After this the action starts again at the original pitch. To stop the effect set add to zero. The last two parameters are zero by default. If they are non-zero they will be used like in WAIT to suspend the execution of the current macro for a given time interval. There actually two commands of this kind: 29 & 30. They are working independendly from each other and combine to quite nice effects if used simultaniously.

Shorthint=Add a sweep to the pitch

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=100, Type=VAL_Normal, Reference=None , Hint=Times
Value = 16bit@byte2, MinValue=-32768, MaxValue=32768, PresetValue=100, Type=VAL_Signed, Reference=None, Hint=Add
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=ms switch
Value = 16bit@byte6, MinValue=0, MaxValue=65535, PresetValue=1000, Type=VAL_Normal, Reference=None, Hint=Ticks/Millisec.

;-------------------------------------------------------------------------------------
[$1e]
Type = Pitch
Name = PITCHSWEEP2
Icon =wave.ico

Mainhint=Adds add times times to the current pitch. After this the action starts again at the original pitch. To stop the effect set add to zero. The last two parameters are zero by default. If they are non-zero they will be used like in WAIT to suspend the execution of the current macro for a given time interval. There actually two commands of this kind: 29 & 30. They are working independendly from each other and combine to quite nice effects if used simultaniously.

Shorthint=Add a sweep to the pitch

Value = 8bit@byte1, MinValue=0, MaxValue=127, PresetValue=66, Type=VAL_Normal, Reference=None , Hint=Times
Value = 16bit@byte2, MinValue=-32768, MaxValue=32768, PresetValue=-333, Type=VAL_Signed, Reference=None, Hint=Add
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=1, Type=VAL_Switch, Reference=None, Hint=ms switch
Value = 16bit@byte6, MinValue=0, MaxValue=65535, PresetValue=333, Type=VAL_Normal, Reference=None, Hint=Ticks/Millisec.

;-------------------------------------------------------------------------------------
