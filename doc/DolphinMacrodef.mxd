[$38]
Type = Special
Name = AGECNTSPEED
Icon =prio1.ico

Mainhint=Changes the speed by which the priority counter of the current voice is decremented. By default the counter will reach zero after about 18 minutes. The time value sets the time in milliseconds the counter will need to decrement to zero from itäs current value. This allowes customized priority handling.

Shorthint=Set priority counter speed

Value = 32bit@byte4, MinValue=0, MaxValue=16777215, PresetValue=1080000, Type=VAL_Normal, Reference=None, Hint=Time

;-------------------------------------------------------------------------------------
[$39]
