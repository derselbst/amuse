; MusyX Soundtool - SMaL Command-definitionfile for Dolphin
;
; Last changed by: Thomas Engel
; Date           : 02/16/2001
; Version	 : 1.01
;
; !!!! Please do not change anything here unless you know exactly what you are doing !!!!
;
[Soundmacro.Commanddef]
System = Dolphin
Name = Dolphin command definition

;
; Sample_Compression_Types:
;
[AudioCompressionTypes]

0=Default
1=PCM16
2=ADPCM
3=ADPCM+
4=PCM8

[CommandTypes]
CMD_Structure
CMD_Sample
CMD_Volume
CMD_Pitch
CMD_Control
CMD_Special
CMD_Setup

;
; possible references=
;
; - none
; - Sample
; - Soundmacro
; - Soundmacrostep
; - Table
; - Keymap
;

;-------------------------------------------------------------------------------------
; Templates
;-------------------------------------------------------------------------------------

; Simple template with keyoff to play any sample
[Template_begin]
Name=?_basic_macro
Macrostep=$38,$00,$00,$00,$C0,$7A,$10,$00
Macrostep=$10,$00,$00,$00,$00,$00,$00,$00
Macrostep=$07,$01,$00,$01,$00,$00,$FF,$FF
Macrostep=$11,$00,$00,$00,$00,$00,$00,$00
Macrostep=$31,$00,$00,$00,$00,$00,$00,$00
Macrostep=$00,$00,$00,$00,$00,$00,$00,$00
[Template_end]

