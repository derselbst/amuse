[$60]
Type = Special
Name = ADD_VARS
Icon =var02.ico

Mainhint=The current values of variable B and C are added together and stored in variable A. There are 32 possible variables. The first 16 variables are local (only for the current macro), whereas the next 16 (16-31) are global for all macros. The Var/Ctrl switches are selecting whether a variable or a controller should be accessed. If the switch is set to "On" (1) the corresponding value index is used as an extended controller number (0-132). Hint: Controllers are handled internally as 14-bit values.

Shorthint=Add vars

Value = 8bit@byte1, MinValue=0, MaxValue=1, PresetValue=0, Type=VAL_Switch, Reference=None , Hint=Var/Ctrl
Value = 8bit@byte2, MinValue=0, MaxValue=255, PresetValue=0, Type=VAL_Normal, Reference=None , Hint=A  =
Value = 8bit@byte3, MinValue=0, MaxValue=1, PresetValue=0, Type=VAL_Switch, Reference=None , Hint=Var/Ctrl
Value = 8bit@byte4, MinValue=0, MaxValue=255, PresetValue=0, Type=VAL_Normal, Reference=None , Hint=B  +
Value = 8bit@byte5, MinValue=0, MaxValue=1, PresetValue=0, Type=VAL_Switch, Reference=None , Hint=Var/Ctrl
Value = 8bit@byte6, MinValue=0, MaxValue=255, PresetValue=0, Type=VAL_Normal, Reference=None , Hint=C

